title: {
  label: "Auto-Sokoban — Architecture en 3 parts"
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

direction: down

part1: "Part 1 — Noyau + BFS\n(dev pilote)" {
  style: {
    fill: "#e3f2fd"
    stroke: "#1976d2"
    stroke-width: 2
  }

  game: "game/" {
    board: "board.py\nBoardState, Board,\ndetect_corner_deadlocks"
  }

  solver_core: "solver/" {
    base: "base.py\nSolver ABC, SolverStep,\nSolverResult, SolverProgress,\nVisitCounts, solve_async"
    bfs: "bfs.py\nBFS (optimal)\n+ _search_async"
  }

  ui_core: "ui/" {
    input: "input.py\nAction, Button (pressed),\npoll_events"
    scenes_base: "scenes/base.py\nScene ABC, SceneManager"
    scenes_game: "scenes/game.py\nGameScene\n(facing, undo, reset)"
  }

  entry: "main.py + build-game.py"
}

part2: "Part 2 — Visualisation + A*\n(Manon)" {
  style: {
    fill: "#fff3e0"
    stroke: "#f57c00"
    stroke-width: 2
  }

  solver_astar: "solver/a_star.py\nA* + heuristique\nManhattan + _search_async"

  ui: "ui/" {
    renderer: "renderer.py\nrendu sprites + heatmap\n+ deadlock overlay"
    metrics: "metrics_panel.py\nlive progress + comparaison\n+ barres + timeline"
    fonts: "fonts.py\npolices embarquees"
    scenes_solver: "scenes/solver.py\nSolverScene (heatmap,\nvitesse, deadlocks)"
  }

  game_level: "game/level.py\nparser XSB, list_levels"
  display: "display-game.py"
}

part3: "Part 3 — Menu + Persistance + DFS\n(Guillaume)" {
  style: {
    fill: "#e8f5e9"
    stroke: "#388e3c"
    stroke-width: 2
  }

  solver_dfs: "solver/dfs.py\nDFS (contre-exemple)\n+ _search_async"

  ui: "ui/" {
    scenes_menu: "scenes/menu.py\nMenuScene pixel-art\n(vignettes, fond assombri)"
    scenes_ranking: "scenes/ranking.py\nRankingScene"
    scenes_race: "scenes/race.py\nRaceScene\n(3 algos paralleles)"
    audio: "audio.py\nmusique + sons"
  }

  db: "game/db.py\nSQLite scores"
  levels: "levels/\n7 niveaux XSB\n(easy, medium, hard)"
  assets: "assets/\nsprites + sons + polices"
}

# Dependencies
part1.ui_core.scenes_game -> part1.game.board: "utilise Board"
part1.solver_core.bfs -> part1.solver_core.base: "implements Solver"
part2.solver_astar -> part1.solver_core.base: "implements Solver"
part3.solver_dfs -> part1.solver_core.base: "implements Solver"
part2.ui.scenes_solver -> part1.solver_core.base: "poll SolverProgress"
part2.ui.scenes_solver -> part2.ui.renderer: "render + overlays"
part2.ui.scenes_solver -> part2.ui.metrics: "affiche"
part3.ui.scenes_menu -> part2.game_level: "liste niveaux"
part3.ui.scenes_menu -> part3.ui.scenes_race: "COURSE ALGO"
part3.ui.scenes_race -> part1.solver_core.base: "3 threads solve_async"
part3.ui.scenes_ranking -> part3.db: "lit scores"

legend: "Part 1 (noyau) est autonome.\nParts 2 et 3 dependent de Part 1\n(via solver/base.py).\nThreading : solve_async + queue\npour les 3 algos." {
  shape: text
  style.font-size: 12
  style.italic: true
  near: bottom-left
}
